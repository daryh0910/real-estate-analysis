# 한국은행 ECOS API (https://ecos.bok.or.kr/api/#/ 에서 발급)
BOK_API_KEY=your_bok_api_key_here

# 공공데이터포털 API (https://www.data.go.kr/ 에서 발급, 디코딩된 키)
DATA_GO_KR_KEY=your_data_go_kr_key_here

# 국토교통부 실거래가 API (URL-encoded 키)
MOLIT_API_KEY=your_molit_api_key_here

# KOSIS 통계정보 API (https://kosis.kr/openapi/ 에서 발급)
KOSIS_API_KEY=your_kosis_api_key_here

# SGIS 통계지리정보 API (https://sgis.mods.go.kr/developer/ 에서 발급)
# 연령대별/성별 인구, 1인가구, 주택통계 등 제공
SGIS_API_KEY=your_sgis_api_key_here
